{
  "info": {
    "name": "SaferNest API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for SaferNest disaster management platform"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "incidentId", "value": "" },
    { "key": "resourceId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "volunteerId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Citizen\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Pass@123\",\n  \"phone\": \"9999999999\",\n  \"role\": \"CITIZEN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Pass@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "Create Incident",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/incidents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Flood Alert\",\n  \"description\": \"Water level rising rapidly\",\n  \"locationLat\": 19.0760,\n  \"locationLng\": 72.8777\n}"
            }
          }
        },
        {
          "name": "Get Incidents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/incidents"
          }
        },
        {
          "name": "Update Incident Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/incidents/{{incidentId}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Resources",
      "item": [
        {
          "name": "Create Resource",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/resources",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"FOOD\",\n  \"quantity\": 100,\n  \"location\": \"City Center\"\n}"
            }
          }
        },
        {
          "name": "Get Resources",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/resources"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"incidentId\": \"{{incidentId}}\",\n  \"status\": \"CREATED\",\n  \"priority\": \"HIGH\"\n}"
            }
          }
        },
        {
          "name": "Get Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tasks"
          }
        },
        {
          "name": "Assign Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tasks/{{taskId}}/assign",
            "body": { "mode": "raw", "raw": "{\n  \"volunteerId\": \"{{volunteerId}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Requests",
      "item": [
        {
          "name": "Create Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/requests",
            "body": { "mode": "raw", "raw": "{\n  \"resourceId\": \"{{resourceId}}\"\n}" }
          }
        },
        {
          "name": "Get Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/requests"
          }
        }
      ]
    }
  ]
}
